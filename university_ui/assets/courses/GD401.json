  "assessments": {
    "quizzes": [
      {
        "quiz": 1,
        "week": 2,
        "topic": "3D Mathematics and Coordinate Systems",
        "duration": "20 minutes",
        "questions": [
          {
            "question": "What is the result of multiplying a 4x4 transformation matrix by a position vector (2, 3, 4, 1) if the matrix represents a translation of (1, 0, 0)?",
            "type": "calculation",
            "points": 10,
            "answer": "(3, 3, 4, 1)",
            "rubric": [
              {
                "key": "Correct final answer",
                "value": 6
              },
              {
                "key": "Proper matrix multiplication shown",
                "value": 3
              },
              {
                "key": "Homogeneous coordinate understanding",
                "value": 1
              }
            ]
          },
          {
            "question": "Explain the primary advantage of using quaternions over Euler angles for 3D rotations.",
            "type": "short_answer",
            "points": 10,
            "answer": "Quaternions avoid gimbal lock, provide smooth interpolation, and are more efficient for combining rotations.",
            "rubric": [
              {
                "key": "Mentions gimbal lock avoidance",
                "value": 4
              },
              {
                "key": "Discusses interpolation benefits",
                "value": 3
              },
              {
                "key": "Notes computational efficiency",
                "value": 3
              }
            ]
          }
        ],
        "total_points": 20
      },
      {
        "quiz": 2,
        "week": 4,
        "topic": "Graphics Pipeline and Shaders",
        "duration": "25 minutes",
        "questions": [
          {
            "question": "List the main stages of the graphics rendering pipeline in order.",
            "type": "short_answer",
            "points": 10,
            "answer": "Vertex processing, primitive assembly, rasterization, fragment processing, per-fragment operations",
            "rubric": [
              {
                "key": "Correct order of stages",
                "value": 6
              },
              {
                "key": "All major stages included",
                "value": 4
              }
            ]
          },
          {
            "question": "Write a simple HLSL vertex shader function that transforms a vertex position from object space to clip space.",
            "type": "code",
            "points": 15,
            "answer": "float4 vertex : SV_Position = mul(UNITY_MATRIX_MVP, input.vertex);",
            "rubric": [
              {
                "key": "Correct matrix multiplication",
                "value": 8
              },
              {
                "key": "Proper HLSL syntax",
                "value": 4
              },
              {
                "key": "Correct semantic usage",
                "value": 3
              }
            ]
          }
        ],
        "total_points": 25
      }
