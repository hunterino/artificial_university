{
  "course_info": {
    "course_id": "GD401",
    "title": "3D Game Development",
    "credit_hours": 4,
    "duration": "15 weeks",
    "meeting_schedule": "Monday, Wednesday, Friday - 3 hours per week",
    "prerequisites": [
      "GD301 - 2D Game Development",
      "CS202 - Object-Oriented Programming",
      "MATH251 - Linear Algebra",
      "CS101 - Computer Graphics Fundamentals"
    ]
  },
  "class_schedule": [
    {
      "week_number": 1,
      "session_number": 1,
      "topic": "Introduction to 3D Game Development",
      "duration": "50 minutes",
      "learning_objectives": [
        "Understand the scope and complexity of 3D game development",
        "Identify key differences between 2D and 3D game development",
        "Overview of modern 3D game engines"
      ],
      "readings": [
        "Game Engine Architecture Ch. 1-2",
        "Real-Time Rendering Ch. 1"
      ],
      "lecture_notes": {
        "introduction": "Welcome to 3D Game Development. This course will take you from 2D concepts into the complex world of three-dimensional interactive experiences.",
        "key_concepts": [
          "3D coordinate systems and transformations",
          "Rendering pipeline overview",
          "Game engine architecture",
          "Performance considerations in 3D",
          "Modern 3D development tools and workflows"
        ],
        "demonstration": "Live demo of Unity 3D interface and basic scene setup",
        "setup_requirements": [
          "Unity 2023.2 LTS installed",
          "Visual Studio or VS Code configured",
          "Git repository access"
        ],
        "review": [
          {
            "key": "3D Coordinate Systems",
            "value": "Right-handed vs left-handed coordinate systems, world vs local space"
          },
          {
            "key": "Rendering Pipeline",
            "value": "Vertex processing, rasterization, fragment shading, post-processing"
          }
        ]
      }
    },
    {
      "week_number": 1,
      "session_number": 2,
      "topic": "3D Mathematics and Transformations",
      "duration": "50 minutes",
      "learning_objectives": [
        "Master 3D vector operations",
        "Understand matrix transformations",
        "Apply quaternions for rotations"
      ],
      "readings": [
        "3D Math Primer Ch. 3-4",
        "Game Engine Architecture Ch. 4"
      ],
      "lecture_notes": {
        "introduction": "Mathematical foundations are crucial for 3D graphics programming. Today we'll cover the essential math concepts.",
        "key_concepts": [
          "Vector operations in 3D space",
          "Matrix multiplication and transformations",
          "Quaternion rotations",
          "Homogeneous coordinates",
          "Transform hierarchies"
        ],
        "demonstration": "Interactive demonstration of transformations using Unity's transform component",
        "setup_requirements": [
          "Calculator or mathematical software",
          "Unity project from previous session"
        ],
        "review": [
          {
            "key": "Transformation Matrix",
            "value": "4x4 matrix combining translation, rotation, and scale"
          },
          {
            "key": "Quaternions",
            "value": "4-component representation of rotation that avoids gimbal lock"
          }
        ]
      }
    },
    {
      "week_number": 2,
      "session_number": 3,
      "topic": "3D Graphics Pipeline and Shaders",
      "duration": "50 minutes",
      "learning_objectives": [
        "Understand the complete graphics rendering pipeline",
        "Learn shader programming basics",
        "Implement vertex and fragment shaders"
      ],
      "readings": [
        "Real-Time Rendering Ch. 2-3",
        "Unity Shader Programming Guide"
      ],
      "lecture_notes": {
        "introduction": "The graphics pipeline is the heart of 3D rendering. Understanding each stage is essential for advanced graphics programming.",
        "key_concepts": [
          "Vertex shader stage",
          "Geometry processing",
          "Rasterization process",
          "Fragment shader operations",
          "HLSL/GLSL shader languages"
        ],
        "demonstration": "Writing a simple vertex/fragment shader pair in Unity",
        "setup_requirements": [
          "Unity ShaderGraph package installed",
          "Basic understanding of linear algebra"
        ],
        "review": [
          {
            "key": "Vertex Shader",
            "value": "Processes individual vertices, handles transformations and lighting calculations"
          },
          {
            "key": "Fragment Shader",
            "value": "Determines final pixel color, handles texturing and complex lighting"
          }
        ]
      }
    },
    {
      "week_number": 3,
      "session_number": 7,
      "topic": "Physics Simulation Fundamentals",
      "duration": "50 minutes",
      "learning_objectives": [
        "Understand basic physics simulation principles",
        "Implement collision detection algorithms",
        "Integrate physics engines into games"
      ],
      "readings": [
        "Game Physics Engine Development Ch. 1-3",
        "Unity Physics Documentation"
      ],
      "lecture_notes": {
        "introduction": "Physics simulation brings realism to 3D games. We'll explore both the theory and practical implementation.",
        "key_concepts": [
          "Newtonian mechanics in games",
          "Collision detection algorithms",
          "Rigid body dynamics",
          "Physics engine integration",
          "Performance optimization for physics"
        ],
        "demonstration": "Setting up physics bodies and collision detection in Unity",
        "setup_requirements": [
          "Unity Physics package",
          "Basic understanding of calculus and physics"
        ],
        "review": [
          {
            "key": "Collision Detection",
            "value": "Broad phase and narrow phase detection, spatial partitioning techniques"
          },
          {
            "key": "Integration Methods",
            "value": "Euler integration vs. Verlet integration for stability"
          }
        ]
      }
    },
    {
      "week_number": 5,
      "session_number": 13,
      "topic": "Advanced Lighting and Visual Effects",
      "duration": "50 minutes",
      "learning_objectives": [
        "Implement advanced lighting models",
        "Create particle systems and visual effects",
        "Optimize rendering performance"
      ],
      "readings": [
        "Real-Time Rendering Ch. 5-7",
        "GPU Gems Ch. 8-12"
      ],
      "lecture_notes": {
        "introduction": "Advanced visual techniques that separate professional games from amateur projects.",
        "key_concepts": [
          "Physically-based rendering (PBR)",
          "Global illumination techniques",
          "Particle systems and effects",
          "Post-processing pipeline",
          "Level-of-detail (LOD) systems"
        ],
        "demonstration": "Creating a complete PBR material and particle effect system",
        "setup_requirements": [
          "Unity HDRP or URP pipeline configured",
          "High-performance graphics card recommended"
        ],
        "review": [
          {
            "key": "PBR Workflow",
            "value": "Albedo, metallic, roughness, and normal maps for realistic materials"
          },
          {
            "key": "Global Illumination",
            "value": "Light bouncing simulation for realistic environmental lighting"
          }
        ]
      }
    }
