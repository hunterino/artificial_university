          "sections": {
            "theoretical_knowledge": {
              "points": 100,
              "questions": [
                {
                  "question": "Explain the differences between forward rendering and deferred rendering, including the advantages and disadvantages of each approach.",
                  "type": "essay",
                  "points": 25,
                  "expected_answer": "Forward rendering processes each light for each object during the geometry pass, while deferred rendering separates geometry and lighting into separate passes. Forward rendering is simpler and better for transparency, while deferred rendering is more efficient for many lights but uses more memory.",
                  "rubric": [
                    {
                      "key": "Explains forward rendering process",
                      "value": 8
                    },
                    {
                      "key": "Explains deferred rendering process",
                      "value": 8
                    },
                    {
                      "key": "Lists advantages and disadvantages",
                      "value": 6
                    },
                    {
                      "key": "Technical accuracy and clarity",
                      "value": 3
                    }
                  ]
                },
                {
                  "question": "Describe the mathematical relationship between model, view, and projection matrices in the graphics pipeline.",
                  "type": "essay",
                  "points": 20,
                  "expected_answer": "The model matrix transforms from object space to world space, the view matrix transforms from world space to camera space, and the projection matrix transforms from camera space to clip space. These are typically combined as MVP = Projection × View × Model.",
                  "rubric": [
                    {
                      "key": "Correctly describes each matrix",
                      "value": 12
                    },
                    {
                      "key": "Shows proper multiplication order",
                      "value": 5
                    },
                    {
                      "key": "Mathematical accuracy",
                      "value": 3
                    }
                  ]
                }
              ]
            },
